{
  "name": "voxvulgi-desktop",
  "private": true,
  "version": "0.1.16",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test:contracts": "node --import tsx --test tests/**/*.test.ts",
    "build:desktop:target": "powershell -ExecutionPolicy Bypass -File ../../governance/scripts/build_desktop_target.ps1",
    "build:desktop:target:no-prep": "powershell -ExecutionPolicy Bypass -File ../../governance/scripts/build_desktop_target.ps1 -SkipOfflineBundlePrep",
    "build:desktop:target:refresh": "powershell -ExecutionPolicy Bypass -File ../../governance/scripts/build_desktop_target.ps1 -RefreshOfflinePayload",
    "build:desktop:target:force-refresh": "powershell -ExecutionPolicy Bypass -File ../../governance/scripts/build_desktop_target.ps1 -ForceRefreshOfflinePayload",
    "build:desktop:payload:validate": "powershell -ExecutionPolicy Bypass -File ../../governance/scripts/build_desktop_target.ps1 -ValidateOfflinePayloadOnly",
    "uninstall:desktop": "powershell -ExecutionPolicy Bypass -File ../../governance/scripts/uninstall_voxvulgi.ps1",
    "uninstall:desktop:force": "powershell -ExecutionPolicy Bypass -File ../../governance/scripts/uninstall_voxvulgi.ps1 -Force",
    "uninstall:desktop:purge": "powershell -ExecutionPolicy Bypass -File ../../governance/scripts/uninstall_voxvulgi.ps1 -Force -PurgeUserData",
    "cleanup:artifacts": "powershell -ExecutionPolicy Bypass -File ../../governance/scripts/cleanup_artifacts.ps1",
    "cleanup:artifacts:force": "powershell -ExecutionPolicy Bypass -File ../../governance/scripts/cleanup_artifacts.ps1 -Force",
    "cleanup:artifacts:full": "powershell -ExecutionPolicy Bypass -File ../../governance/scripts/cleanup_artifacts.ps1 -Force -IncludeBuildTarget -PruneOldBuilds",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "html2canvas": "^1.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tsx": "^4.20.5",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
